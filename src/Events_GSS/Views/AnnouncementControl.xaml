<UserControl
    x:Class="Events_GSS.Views.AnnouncementControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Events_GSS.ViewModels"
    xmlns:models="using:Events_GSS.Data.Models"
    xmlns:conv="using:Events_GSS.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:NullToCollapsedConverter x:Key="NullToCollapsed" />
        <conv:ExpandChevronConverter x:Key="ExpandChevron" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ═══════════════════════════════════════════════════════
             ROW 0 — Error Banner
             ═══════════════════════════════════════════════════════ -->
        <Border
            Grid.Row="0"
            Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
            CornerRadius="4"
            Padding="12,8"
            Margin="8,4"
            Visibility="{x:Bind ViewModel.ErrorVisibility, Mode=OneWay}">
            <TextBlock
                Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                TextWrapping="Wrap" />
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             ROW 1 — Admin: Create / Edit Input (admin only)
             ═══════════════════════════════════════════════════════ -->
        <Border
            Grid.Row="1"
            Visibility="{x:Bind ViewModel.IsEventAdmin, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
            Padding="12,8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">

            <StackPanel Spacing="8">
                <!-- Editing indicator -->
                <Border
                    Visibility="{x:Bind ViewModel.IsEditing, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                    Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                    CornerRadius="4"
                    Padding="8,4">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock
                            Grid.Column="0"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}">
                            <Run Text="Editing announcement #" /><Run Text="{x:Bind ViewModel.EditingAnnouncement.Id, Mode=OneWay, FallbackValue=''}" />
                        </TextBlock>
                        <Button
                            Grid.Column="1"
                            Command="{x:Bind ViewModel.CancelEditCommand}"
                            ToolTipService.ToolTip="Cancel edit">
                            <FontIcon Glyph="&#xE711;" FontSize="12" />
                        </Button>
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,Auto">
                    <TextBox
                        Grid.Column="0"
                        Text="{x:Bind ViewModel.NewMessage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Write an announcement..."
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        MinHeight="60"
                        MaxHeight="150"
                        IsEnabled="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}"
                        Margin="0,0,8,0" />

                    <Button
                        Grid.Column="1"
                        Content="{x:Bind ViewModel.CreateButtonText, Mode=OneWay}"
                        Command="{x:Bind ViewModel.SubmitAnnouncementCommand}"
                        VerticalAlignment="Bottom"
                        Style="{ThemeResource AccentButtonStyle}" />
                </Grid>

                <!-- Unread count -->
                <TextBlock
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="Unread by participants: " /><Run Text="{x:Bind ViewModel.UnreadCount, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             ROW 2 — Announcements List
             ═══════════════════════════════════════════════════════ -->
        <ListView
            x:Name="AnnouncementsListView"
            Grid.Row="2"
            ItemsSource="{x:Bind ViewModel.Announcements, Mode=OneWay}"
            SelectionMode="None"
            Padding="8,4">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0,2" />
                    <Setter Property="Margin" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:AnnouncementItemViewModel">
                    <Grid
                        CornerRadius="6"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Margin="0,2">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- ── Header (always visible, clickable to expand) ── -->
                        <Grid
                            Grid.Row="0"
                            Padding="12,10"
                            Tag="{x:Bind}"
                            Tapped="OnAnnouncementHeaderTapped"
                            Background="Transparent">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Unread dot -->
                            <Ellipse
                                Grid.Column="0"
                                Width="8" Height="8"
                                Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind IsUnread, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                            <!-- Pin icon -->
                            <FontIcon
                                Grid.Column="1"
                                Glyph="&#xE718;"
                                FontSize="14"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Visibility="{x:Bind IsPinned, Converter={StaticResource BoolToVisibility}}" />

                            <!-- Preview text + author + time -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock
                                    Text="{x:Bind PreviewText}"
                                    Style="{ThemeResource BodyTextBlockStyle}"
                                    MaxLines="1"
                                    TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock
                                        Text="{x:Bind Author.Name, FallbackValue='Unknown'}"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock
                                        Text="{x:Bind Date}"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <Border
                                        Visibility="{x:Bind IsEdited, Converter={StaticResource BoolToVisibility}}"
                                        Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                                        CornerRadius="2"
                                        Padding="4,1">
                                        <TextBlock
                                            Text="edited"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            FontStyle="Italic" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- Expand/collapse chevron -->
                            <FontIcon
                                Grid.Column="4"
                                Glyph="{x:Bind IsExpanded, Mode=OneWay, Converter={StaticResource ExpandChevron}}"
                                FontSize="12"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>

                        <!-- ── Expanded Content ────────────────────── -->
                        <StackPanel
                            Grid.Row="1"
                            Visibility="{x:Bind IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                            Padding="12,0,12,8"
                            Spacing="8">

                            <!-- Full message -->
                            <TextBlock
                                Text="{x:Bind Message}"
                                TextWrapping="Wrap"
                                Style="{ThemeResource BodyTextBlockStyle}" />
                        </StackPanel>

                        <!-- ── Reactions (visible when expanded) ───── -->
                        <ItemsRepeater
                            Grid.Row="2"
                            ItemsSource="{x:Bind ReactionGroups, Mode=OneWay}"
                            Margin="12,0,12,4"
                            Visibility="{x:Bind IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="4" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:ReactionGroup">
                                    <Border
                                        Padding="6,2"
                                        CornerRadius="10"
                                        BorderThickness="1"
                                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{x:Bind Emoji}" FontSize="14" />
                                            <TextBlock Text="{x:Bind Count}" FontSize="12"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <!-- ── Actions (visible when expanded) ─────── -->
                        <StackPanel
                            Grid.Row="3"
                            Orientation="Horizontal"
                            Spacing="4"
                            Padding="12,0,12,8"
                            Visibility="{x:Bind IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">

                            <!-- React button (all users) -->
                            <Button FontSize="12" Padding="6,2" Tag="{x:Bind}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE76E;" FontSize="12" />
                                    <TextBlock Text="React" />
                                </StackPanel>
                                <Button.Flyout>
                                    <Flyout>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Button Content="👍" Click="OnEmojiClicked" Tag="👍" FontSize="18" Padding="6,2" />
                                            <Button Content="❤️" Click="OnEmojiClicked" Tag="❤️" FontSize="18" Padding="6,2" />
                                            <Button Content="😂" Click="OnEmojiClicked" Tag="😂" FontSize="18" Padding="6,2" />
                                            <Button Content="😮" Click="OnEmojiClicked" Tag="😮" FontSize="18" Padding="6,2" />
                                            <Button Content="😢" Click="OnEmojiClicked" Tag="😢" FontSize="18" Padding="6,2" />
                                            <Button Content="🔥" Click="OnEmojiClicked" Tag="🔥" FontSize="18" Padding="6,2" />
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>

                            <!-- Admin-only: Edit, Delete, Pin -->
                            <Button
                                Content="✏️ Edit"
                                FontSize="12"
                                Padding="6,2"
                                Tag="{x:Bind}"
                                Visibility="{x:Bind IsCurrentUserAdmin, Converter={StaticResource BoolToVisibility}}"
                                Click="OnEditClicked" />

                            <Button
                                Content="🗑 Delete"
                                FontSize="12"
                                Padding="6,2"
                                Tag="{x:Bind}"
                                Visibility="{x:Bind IsCurrentUserAdmin, Converter={StaticResource BoolToVisibility}}"
                                Click="OnDeleteClicked" />

                            <Button
                                FontSize="12"
                                Padding="6,2"
                                Tag="{x:Bind}"
                                Visibility="{x:Bind IsCurrentUserAdmin, Converter={StaticResource BoolToVisibility}}"
                                Click="OnPinClicked">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE718;" FontSize="12" />
                                    <TextBlock Text="Pin" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.Footer>
                <TextBlock
                    x:Name="EmptyStateText"
                    Text="No announcements yet."
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center"
                    Margin="0,24"
                    Visibility="Collapsed" />
            </ListView.Footer>
        </ListView>

        <!-- Loading overlay -->
        <ProgressRing
            Grid.Row="2"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center" />
    </Grid>
</UserControl>
