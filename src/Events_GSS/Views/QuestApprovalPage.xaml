<Page
    x:Class="Events_GSS.Views.QuestApprovalPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Events_GSS.Views"
    xmlns:models="using:Events_GSS.Data.Models">

    <Grid ColumnDefinitions="*, 450">
        <local:QuestAdminControl 
            Grid.Column="0"
            ViewModel="{x:Bind ViewModel.QuestAdminVM, Mode=OneWay}" />

        <Grid Grid.Column="1" Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" Padding="16">
            <Grid RowDefinitions="Auto, *">

                <StackPanel Spacing="4" Margin="0,0,0,16">
                    <TextBlock Text="Review Submissions" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="{x:Bind ViewModel.QuestAdminVM.SelectedQuest.Name, Mode=OneWay, FallbackValue='Select a quest'}" 
                               Foreground="{ThemeResource SystemAccentColorLight2}"/>
                </StackPanel>

                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Submissions, Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:QuestMemory">
                            <StackPanel Spacing="8" Margin="0,8" Padding="12" 
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        CornerRadius="8">

                                <TextBlock Text="{x:Bind Proof.Author.Name, TargetNullValue='No descr'}" FontWeight="Bold"/>
<!--
                                <Image Source="{x:Bind Proof.PhotoPath, TargetNullValue='https://en.wikipedia.org/wiki/Cat#/media/File:Cat_August_2010-4.jpg'}"
                                       Visibility="{x:Bind local:QuestApprovalPage.GetVisibility(Proof.PhotoPath)}"
                                       MaxHeight="200"
                                       Stretch="UniformToFill"/>
                                -->
                                <Image Source="{x:Bind local:QuestApprovalPage.GetImageSource(Proof.PhotoPath)}"
                                       Visibility="{x:Bind local:QuestApprovalPage.GetVisibility(Proof.PhotoPath)}"
                                       MaxHeight="200"
                                       Stretch="UniformToFill"/>

                                <TextBlock Text="{x:Bind Proof.Text, TargetNullValue='No descr'}" TextWrapping="Wrap" FontStyle="Italic"/>

                                <Grid ColumnDefinitions="*, *" ColumnSpacing="8" Margin="8,8,0,0">
                                    <Button Grid.Column="0" 
                                            Content="Approve" 
                                            HorizontalAlignment="Stretch"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="ApproveButton_Click"/>

                                    <Button Grid.Column="1" 
                                            Content="Deny" 
                                            HorizontalAlignment="Stretch"
                                            Click="DenyButton_Click"/>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <ProgressRing IsActive="{x:Bind ViewModel.IsLoadingSubmissions, Mode=OneWay}" 
                              Grid.Row="1" VerticalAlignment="Center"/>
            </Grid>
        </Grid>
    </Grid>
</Page>