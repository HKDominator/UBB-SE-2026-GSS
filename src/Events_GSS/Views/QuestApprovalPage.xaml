<Page
    x:Class="Events_GSS.Views.QuestApprovalPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Events_GSS.Views"
    xmlns:models="using:Events_GSS.Data.Models"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition x:Name="SubmissionsColumn" Width="450" MinWidth="200" MaxWidth="800" />
        </Grid.ColumnDefinitions>

        <local:QuestAdminControl 
            Grid.Column="0"
            ViewModel="{x:Bind ViewModel.QuestAdminVM, Mode=OneWay}" />

        <controls:GridSplitter Grid.Column="1" 
                      Width="4" 
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      ResizeBehavior="BasedOnAlignment" />

        <Grid Grid.Column="2" 
              Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" 
              Padding="16"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="1,0,0,0">

            <Grid RowDefinitions="Auto, *">
                <StackPanel Spacing="4" Margin="0,0,0,16">
                    <Grid>
                        <TextBlock Text="Review Submissions" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    </Grid>
                    <TextBlock Text="{x:Bind ViewModel.QuestAdminVM.SelectedQuest.Name, Mode=OneWay, FallbackValue='Select a quest'}" 
                               Foreground="{ThemeResource SystemAccentColorLight2}"/>
                </StackPanel>

                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Submissions, Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:QuestMemory">
                            <Viewbox MaxHeight="500">
                            <StackPanel Spacing="8" Margin="0,8" Padding="12" 
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        CornerRadius="8">

                                <TextBlock Text="{x:Bind Proof.Author.Name, TargetNullValue='No descr'}" FontWeight="Bold"/>

                                <Image Source="{x:Bind local:QuestApprovalPage.GetImageSource(Proof.PhotoPath)}"
                                       Visibility="{x:Bind local:QuestApprovalPage.GetVisibility(Proof.PhotoPath)}"
                                       MaxHeight="400"
                                       Stretch="Uniform"/>

                                <TextBlock Text="{x:Bind Proof.Text, TargetNullValue='No descr'}" TextWrapping="Wrap" FontStyle="Italic" MinWidth="300"/>

                                <Grid ColumnDefinitions="*, *" ColumnSpacing="8" Margin="8,8,0,0">
                                    <Button Grid.Column="0" 
                                            Content="Approve" 
                                            HorizontalAlignment="Stretch"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="ApproveButton_Click"/>

                                    <Button Grid.Column="1" 
                                            Content="Deny" 
                                            HorizontalAlignment="Stretch"
                                            Click="DenyButton_Click"/>
                                </Grid>
                            </StackPanel>
                                </Viewbox>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <ProgressRing IsActive="{x:Bind ViewModel.IsLoadingSubmissions, Mode=OneWay}" 
                              Grid.Row="1" VerticalAlignment="Center"/>
            </Grid>
        </Grid>
    </Grid>
</Page>