<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Events_GSS.Views.EventListingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Events_GSS.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Events_GSS.Data.Models"
    xmlns:conv="using:Events_GSS.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!--<RowDefinition Height="Auto"/> -->

            <RowDefinition Height="Auto"/> 

            <RowDefinition Height="*"/> 

            <RowDefinition Height="Auto"/> 
            
        </Grid.RowDefinitions>
        
        <!-- TOP: NAVIGATION BAR-->
        <!--<local:NavigationBar Grid.Row="0"/>-->

        <!-- SEARCH + FILTER ROW      -->
        <Grid Grid.Row="1" Padding="16,12" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox
                Grid.Column="0"
                PlaceholderText="Search events..."
                Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <Button Grid.Column="1">
                <Button.Flyout>
                    <Flyout>
                        <StackPanel Spacing="12" Width="260">
                            <TextBlock Text="Filters" Style="{ThemeResource TitleTextBlockStyle}"/>

                            <ComboBox
                                Header="Category"
                                HorizontalAlignment="Stretch"
                                ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                                DisplayMemberPath="Title"/>

                            <TextBox
                                Header="Location"
                                PlaceholderText="Enter location..."
                                Text="{x:Bind ViewModel.LocationFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <DatePicker
                                Header="Date"
                                SelectedDate="{x:Bind ViewModel.DateFilter, Mode=TwoWay}"/>

                            <DatePicker
                                Header="End Date (for range)"
                                SelectedDate="{x:Bind ViewModel.DateRangeEnd, Mode=TwoWay}"/>

            <Button
                                Content="Apply Filters"
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.FilterCommand}"/>

                            <Button
                                Content="Clear Filters"
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.ClearFiltersCommand}"/>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE71C;" FontSize="14"/>
                    <TextBlock Text="Filters"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- EVENTS LIST   -->
        <ScrollViewer Grid.Row="2" Padding="16,0">
            <StackPanel Spacing="12">

                <TextBlock
                    Text="No events found."
                    Visibility="{x:Bind ViewModel.NoResultsVisibility, Mode=OneWay}"
                    HorizontalAlignment="Center"
                    Margin="0,40,0,0"
                    Style="{ThemeResource BodyTextBlockStyle}"/>

                <ProgressRing
                    IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                    HorizontalAlignment="Center"/>

                <ItemsControl ItemsSource="{x:Bind ViewModel.Events, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Event">
                            <Border
        BorderBrush="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8"
        Margin="0,0,0,4"
        Tapped="OnEventCardTapped"
        Background="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Event Banner -->
                                    <Border
                Grid.Column="0"
                CornerRadius="8,0,0,8"
                Background="{ThemeResource SystemFillColorSolidNeutralBackgroundBrush}">
                                        <Image
                    Source="{x:Bind EventBannerPath}"
                    Stretch="UniformToFill"
                    Height="140"/>
                                    </Border>

                                    <!-- Event Info -->
                                    <StackPanel Grid.Column="1" Padding="16,12" Spacing="4">

                                        <Border
                    Background="{ThemeResource AccentAAFillColorDefaultBrush}"
                    CornerRadius="4"
                    Padding="8,2"
                    HorizontalAlignment="Left">
                                            <TextBlock
                        Text="{x:Bind Category.Title, FallbackValue='No Category'}"
                        FontSize="11"
                        FontWeight="SemiBold"/>
                                        </Border>

                                        <TextBlock
                    Text="{x:Bind Name}"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    TextWrapping="Wrap"/>

                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE787;" FontSize="13"/>
                                            <TextBlock
                        Text="{x:Bind StartDateTime}"
                        Style="{ThemeResource CaptionTextBlockStyle}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE707;" FontSize="13"/>
                                            <TextBlock
                        Text="{x:Bind Location}"
                        Style="{ThemeResource CaptionTextBlockStyle}"/>
                                        </StackPanel>

                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE716;" FontSize="13"/>
                                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}">
                            <Run Text="{x:Bind EnrolledCount}"/>
                            <Run Text="/"/>
                            <Run Text="{x:Bind MaximumPeople, FallbackValue='∞'}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Join button removed from listing cards; available on event details page -->
                                        </Grid>

                                    </StackPanel>
                                    <!-- closes Event Info StackPanel -->
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <!-- BOTTOM: ADD EVENT BUTTON -->
        <Button
            Grid.Row="3"
            Content="+ Add Event"
            Command="{x:Bind ViewModel.NavigateToCreateCommand}"
            Margin="16"
            HorizontalAlignment="Left"
            Style="{ThemeResource AccentButtonStyle}"/>

        <!-- Removed static loading ring that overlapped the search bar. Use the per-list ProgressRing bound to ViewModel.IsLoading instead. -->
    </Grid>
</Page>
