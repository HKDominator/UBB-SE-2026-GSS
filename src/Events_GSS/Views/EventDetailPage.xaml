<Page
    x:Class="Events_GSS.Views.EventDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Events_GSS.Views">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header ──────────────────────────────────────── -->
        <Grid
            Grid.Row="0"
            Padding="16,12"
            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
            ColumnDefinitions="Auto,*">

            <Button
                Grid.Column="0"
                Click="OnBackClicked"
                VerticalAlignment="Center"
                Margin="0,0,12,0">
                <FontIcon Glyph="&#xE72B;" FontSize="16" />
            </Button>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock
                    x:Name="EventNameText"
                    Style="{ThemeResource TitleTextBlockStyle}"
                    Text="Event" />
                <TextBlock
                    x:Name="EventInfoText"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Button
                x:Name="StatisticsButton"
                Grid.Column="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,16,0"
                Click="OnStatisticsClicked"
                Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE9D9;" FontSize="16" />
                    <TextBlock Text="Statistics" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- ── Tabs ────────────────────────────────────────── -->
        <Pivot Grid.Row="1">

            <PivotItem Header="Announcements">
                <views:AnnouncementControl x:Name="AnnouncementTab" />
            </PivotItem>

            <PivotItem Header="Discussions">
                <views:DiscussionControl x:Name="DiscussionTab" />
            </PivotItem>

            <PivotItem Header="Quests">
                <StackPanel>
                    <views:QuestUserPage x:Name="QuestUserTab"
                                         Visibility="Visible"/>
                    <views:QuestApprovalPage x:Name="QuestAdminTab" 
                                             Visibility="Collapsed"/>
                </StackPanel>
            </PivotItem>

            <PivotItem Header="Memories">
                <views:MemoryView x:Name="MemoryTab" />
            </PivotItem>

        </Pivot>
    </Grid>
</Page>
