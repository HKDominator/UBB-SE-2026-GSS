<Page
    x:Class="Events_GSS.Views.EventDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Events_GSS.Views">

<Grid RowDefinitions="Auto,Auto,*">

        <!-- ── Header ──────────────────────────────────────── -->
        <Grid
            Grid.Row="0"
            Padding="16,12"
            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
            ColumnDefinitions="Auto,*">

            <Button
                Grid.Column="0"
                Click="OnBackClicked"
                VerticalAlignment="Center"
                Margin="0,0,12,0">
                <FontIcon Glyph="&#xE72B;" FontSize="16" />
            </Button>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock
                    x:Name="EventNameText"
                    Style="{ThemeResource TitleTextBlockStyle}"
                    Text="Event" />
                <TextBlock
                    x:Name="EventInfoText"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- ── Event Details ─────────────────────────────────── -->
        <Grid Grid.Row="1" Padding="16,12" ColumnDefinitions="*,Auto" Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
            <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock x:Name="EventDateRangeText" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="ParticipantsText" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="DescriptionText" TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}" />
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="JoinButton" Click="OnJoinLeaveClicked" Content="Join Event" />
            </StackPanel>
        </Grid>

        <!-- ── Tabs ────────────────────────────────────────── -->
        <Pivot Grid.Row="2">

            <PivotItem Header="Announcements">
                <views:AnnouncementControl x:Name="AnnouncementTab" />
            </PivotItem>

            <PivotItem Header="Discussions">
                <views:DiscussionControl x:Name="DiscussionTab" />
            </PivotItem>

            <PivotItem Header="Quests">
                <StackPanel>
                    <views:QuestUserPage x:Name="QuestUserTab" />
                    <views:QuestApprovalPage x:Name="QuestAdminTab" />
                </StackPanel>
            </PivotItem>

            <PivotItem Header="Memories">
                <views:MemoryView x:Name="MemoryTab" />
            </PivotItem>

        </Pivot>
    </Grid>
</Page>
