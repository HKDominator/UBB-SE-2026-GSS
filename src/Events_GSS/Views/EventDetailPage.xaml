<Page
    x:Class="Events_GSS.Views.EventDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Events_GSS.Views">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header ──────────────────────────────────────── -->
        <Grid
            Grid.Row="0"
            Padding="16,12"
            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
            ColumnDefinitions="Auto,*,Auto">

            <Button
                Grid.Column="0"
                Click="OnBackClicked"
                VerticalAlignment="Center"
                Margin="0,0,12,0">
                <FontIcon Glyph="&#xE72B;" FontSize="16" />
            </Button>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock
                    x:Name="EventNameText"
                    Style="{ThemeResource TitleTextBlockStyle}"
                    Text="Event" />
                <TextBlock
                    x:Name="EventInfoText"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Button
                Grid.Column="2"
                x:Name="StatsButton"
                Content="View statistics"
                VerticalAlignment="Center"
                Margin="12,0,0,0"
                Visibility="Collapsed"
                Click="OnStatsClicked" />
        </Grid>

        <!-- ── Tabs ────────────────────────────────────────── -->
        <Pivot Grid.Row="1">

            <PivotItem Header="Announcements">
                <views:AnnouncementControl x:Name="AnnouncementTab" />
            </PivotItem>

            <PivotItem Header="Discussions">
                <views:DiscussionControl x:Name="DiscussionTab" />
            </PivotItem>

            <PivotItem Header="Quests">
                <StackPanel>
                    <views:QuestUserPage x:Name="QuestUserTab"
                                         Visibility="Visible"/>
                    <views:QuestApprovalPage x:Name="QuestAdminTab" 
                                             Visibility="Collapsed"/>
                </StackPanel>
            </PivotItem>

            <PivotItem Header="Memories">
                <views:MemoryView x:Name="MemoryTab" />
            </PivotItem>

        </Pivot>
    </Grid>
</Page>
