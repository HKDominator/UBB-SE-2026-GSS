<Page
    x:Class="Events_GSS.Views.StatisticsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Events_GSS.Data.Models"
     xmlns:conv="using:Events_GSS.Converters">
    <Page.Resources>
        <conv:BoolToInverseVisibilityConverter x:Key="BoolToInverseVisibilityConverter"/>
    </Page.Resources>

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock
            Grid.Row="0"
            Text="Participant Leaderboard"
            Style="{StaticResource TitleTextBlockStyle}"/>

        <!-- Error -->
        <InfoBar
            Grid.Row="1"
            IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
            Severity="Error"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>

        <!-- Loading -->
        <ProgressRing
            Grid.Row="2"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>

        <!-- Leaderboard List -->
        <ListView
            Grid.Row="2"
            ItemsSource="{x:Bind ViewModel.Leaderboard, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToInverseVisibilityConverter}}"
            SelectionMode="None">
            <ListView.Header>
                <Grid Padding="12,8" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="#"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="Player"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="2" Text="Tier"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="3" Text="Msgs"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="4" Text="Mems"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="5" Text="Quests"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="6" Text="Score"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:LeaderboardEntry">
                    <Grid Padding="12,10" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <!-- Rank — no rank property on model, use converter or leave blank -->
                        <TextBlock Grid.Column="0"
                            Text="—"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            VerticalAlignment="Center"/>

                        <!-- Name -->
                        <TextBlock Grid.Column="1"
                            Text="{x:Bind Participant.Name}"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            VerticalAlignment="Center"
                            TextTrimming="CharacterEllipsis"/>

                        <!-- Tier 
                        <TextBlock Grid.Column="2"
                            Text="{x:Bind Participant.Tier}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            VerticalAlignment="Center"/-->

                        <!-- Messages -->
                        <TextBlock Grid.Column="3"
                            Text="{x:Bind MessagesCount}"
                            Style="{StaticResource BodyTextBlockStyle}"
                            VerticalAlignment="Center"/>

                        <!-- Memories -->
                        <TextBlock Grid.Column="4"
                            Text="{x:Bind MemoriesCount}"
                            Style="{StaticResource BodyTextBlockStyle}"
                            VerticalAlignment="Center"/>

                        <!-- Quests -->
                        <TextBlock Grid.Column="5"
                            Text="{x:Bind QuestsCompleted}"
                            Style="{StaticResource BodyTextBlockStyle}"
                            VerticalAlignment="Center"/>

                        <!-- Score -->
                        <TextBlock Grid.Column="6"
                            Text="{x:Bind TotalScore}"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>