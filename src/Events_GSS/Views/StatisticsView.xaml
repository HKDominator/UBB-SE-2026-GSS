<Page
    x:Class="Events_GSS.Views.StatisticsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Events_GSS.Data.Models"
    xmlns:converters="using:Events_GSS.Converters"
    x:Name="Root">

    <Page.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:BoolToInverseVisibilityConverter x:Key="BoolToInverseVisibilityConverter"/>
        <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
    </Page.Resources>

    <Grid RowDefinitions="Auto,*" Padding="24" RowSpacing="16">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
                <TextBlock
                    Text="Leaderboard"
                    Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock
                    Text="{Binding CurrentEvent.Name}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    FontSize="14"
                    Visibility="{Binding CurrentEvent, Converter={StaticResource NullToVisibilityConverter}}" />
            </StackPanel>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1">

            <!-- Loading -->
            <ProgressRing
                IsActive="{Binding IsLoading}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding IsLoading}" />

            <!-- Error -->
            <TextBlock
                Text="{Binding ErrorMessage}"
                Foreground="Red"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

            <!-- Leaderboard list -->
            <ListView
                ItemsSource="{Binding Leaderboard}"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToInverseVisibilityConverter}}">

                <ListView.Header>
                    <!-- Column headers -->
                    <Border
                        Padding="16,8"
                        Margin="0,0,0,4"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8">
                        <Grid ColumnDefinitions="48,*,Auto">
                            <TextBlock
                                Grid.Column="0"
                                Text="#"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock
                                Grid.Column="1"
                                Text="User"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock
                                Grid.Column="2"
                                Text="⭐ RP"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>
                    </Border>
                </ListView.Header>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:LeaderboardEntry">
                        <Border
                            Padding="16,12"
                            Margin="0,4"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                            <Grid ColumnDefinitions="48,*,Auto">

                                <!-- Rank -->
                                <TextBlock
                                    Grid.Column="0"
                                    Text="{Binding Rank}"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center" />

                                <!-- User info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock
                                        Text="{Binding UserName}"
                                        Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock
                                        Text="{Binding EventsAttended}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        FontSize="13" />
                                </StackPanel>

                                <!-- RP -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="⭐" FontSize="14" />
                                    <TextBlock
                                        Text="{Binding ReputationPoints}"
                                        FontSize="16"
                                        FontWeight="SemiBold" />
                                </StackPanel>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>

                <ListView.Footer>
                    <TextBlock
                        Text="No entries yet."
                        HorizontalAlignment="Center"
                        Margin="0,24"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="{Binding Leaderboard.Count,
                            Converter={StaticResource ZeroToVisibilityConverter}}" />
                </ListView.Footer>

            </ListView>
        </Grid>
    </Grid>
</Page>