<Page
    x:Class="Events_GSS.Views.QuestUserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Events_GSS.ViewModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <StackPanel Grid.Row="0" Padding="16,16,16,8" Spacing="2">
            <TextBlock Text="Quests" Style="{StaticResource TitleLargeTextBlockStyle}"/>
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Margin="16,0"
                   Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                   Foreground="Red"
                   Visibility="{x:Bind ViewModel.HasError, Mode=OneWay}"/>

        <Grid Grid.Row="2" Padding="16,8" ColumnDefinitions="Auto,*,Auto">
            <ComboBox Grid.Column="0"
                      SelectedIndex="{x:Bind ViewModel.SelectedFilterIndex, Mode=TwoWay}">
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="Submitted"/>
                <ComboBoxItem Content="Completed"/>
                <ComboBoxItem Content="Incomplete"/>
            </ComboBox>
            <ProgressRing Grid.Column="2"
                          IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="20" Height="20"/>
        </Grid>

        <Grid Grid.Row="3"
              ColumnDefinitions="*,2*,80,*,100,160"
              Padding="16,4"
              VerticalAlignment="Top"
              Canvas.ZIndex="1"
              Background="{ThemeResource SubtleFillColorSecondaryBrush}">
            <TextBlock Grid.Column="0" Text="Name"         Style="{StaticResource CaptionTextBlockStyle}"/>
            <TextBlock Grid.Column="1" Text="Description"  Style="{StaticResource CaptionTextBlockStyle}"/>
            <TextBlock Grid.Column="2" Text="Difficulty"   Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="3" Text="Prerequisite" Style="{StaticResource CaptionTextBlockStyle}"/>
            <TextBlock Grid.Column="4" Text="Status"       Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="5" Text="Actions"      Style="{StaticResource CaptionTextBlockStyle}" Margin="8,0,0,0"/>
        </Grid>

        <ListView Grid.Row="3"
                  Margin="0,32,0,0"
                  ItemsSource="{x:Bind ViewModel.Quests, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedQuest, Mode=TwoWay}"
                  SelectionMode="Single">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:QuestItemViewModel">
                    <Grid ColumnDefinitions="*,2*,80,*,100,160" Padding="16,8">

                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind Name}"
                                   Style="{ThemeResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>

                        <ScrollViewer Grid.Column="1"
                                      VerticalScrollBarVisibility="Auto"
                                      MaxHeight="80"
                                      Margin="0,0,8,0">
                            <TextBlock Text="{x:Bind Description}"
                                       Style="{ThemeResource BodyTextBlockStyle}"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>

                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind DifficultyStars}"
                                   Style="{ThemeResource BodyTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>

                        <Expander Grid.Column="3"
                                  Header="{x:Bind PrerequisiteHint}"
                                  IsExpanded="False"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0">
                            <StackPanel Spacing="6" Padding="4">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Difficulty:" 
                                               Style="{ThemeResource CaptionTextBlockStyle}" 
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Bind Quest.PrerequisiteQuest.Difficulty, FallbackValue='—'}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"/>
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="Description:" 
                                               Style="{ThemeResource CaptionTextBlockStyle}" 
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Bind Quest.PrerequisiteQuest.Description, FallbackValue='—'}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <TextBlock Grid.Column="4"
                                   Text="{x:Bind StatusLabel}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>

                        <StackPanel Grid.Column="5"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Padding="8,0,0,0"
                                    VerticalAlignment="Center">
                            <Button Content="Submit"
                                    Visibility="{x:Bind CanSubmit, Mode=OneWay}"
                                    Tag="{x:Bind}"
                                    Click="OnSubmitClicked"/>
                            <Button Content="Delete"
                                    Visibility="{x:Bind CanDelete, Mode=OneWay}"
                                    Tag="{x:Bind}"
                                    Click="OnDeleteClicked"
                                    Style="{StaticResource AccentButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>