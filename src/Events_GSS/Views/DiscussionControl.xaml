<UserControl
    x:Class="Events_GSS.Views.DiscussionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Events_GSS.ViewModels"
    xmlns:models="using:Events_GSS.Data.Models"
    xmlns:conv="using:Events_GSS.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:NullToCollapsedConverter x:Key="NullToCollapsed" />
        <conv:MentionForegroundConverter x:Key="MentionForeground" />
        <conv:MentionFontWeightConverter x:Key="MentionFontWeight" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

        <!-- ═══════════════════════════════════════════════════════
             ROW 0 — Error Banner
             ═══════════════════════════════════════════════════════ -->
        <Border
            Grid.Row="0"
            Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
            CornerRadius="4"
            Padding="12,8"
            Margin="8,4"
            Visibility="{x:Bind ViewModel.ErrorVisibility, Mode=OneWay}">
            <TextBlock
                Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                TextWrapping="Wrap" />
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             ROW 1 — Admin Controls (Slow Mode)
             ═══════════════════════════════════════════════════════ -->
        <Border
            Grid.Row="1"
            Visibility="{x:Bind ViewModel.IsEventAdmin, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,8">

            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto">
                <FontIcon
                    Grid.Column="0"
                    Glyph="&#xE916;"
                    FontSize="14"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0" />

                <TextBlock
                    Grid.Column="1"
                    Text="{x:Bind ViewModel.SlowModeStatusText, Mode=OneWay}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0" />

                <Button
                    Grid.Column="2"
                    Content="Configure"
                    FontSize="12"
                    Padding="8,4"
                    Click="OnConfigureSlowModeClicked"
                    Margin="0,0,4,0" />

                <Button
                    Grid.Column="3"
                    Content="Turn Off"
                    FontSize="12"
                    Padding="8,4"
                    Click="OnDisableSlowModeClicked"
                    Visibility="{x:Bind ViewModel.IsSlowModeActive, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             ROW 2 — Messages List
             ═══════════════════════════════════════════════════════ -->
        <ListView
            x:Name="MessagesListView"
            Grid.Row="2"
            ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}"
            SelectionMode="None"
            Padding="8,4">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0,2" />
                    <Setter Property="Margin" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:DiscussionMessageItemViewModel">
                    <Grid
                        Padding="10,8"
                        CornerRadius="6"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Margin="0,2">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- ── Reply Reference ─────────────────────── -->
                        <Border
                            Grid.Row="0"
                            Visibility="{x:Bind ReplyTo, Mode=OneWay, Converter={StaticResource NullToCollapsed}}"
                            Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                            CornerRadius="4"
                            Padding="8,4"
                            Margin="0,0,0,6"
                            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                            BorderThickness="2,0,0,0">
                            <StackPanel>
                                <TextBlock
                                    Text="{x:Bind ReplyTo.Author.Name, Mode=OneWay, FallbackValue=''}"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{x:Bind ReplyTo.Message, Mode=OneWay, FallbackValue='[deleted message]'}"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    MaxLines="1"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>

                        <!-- ── Deleted-original indicator ──────────── -->
                        <Border
                            Grid.Row="0"
                            Visibility="{x:Bind IsOriginalDeleted, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                            Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                            CornerRadius="4"
                            Padding="8,4"
                            Margin="0,0,0,6"
                            Opacity="0.6">
                            <TextBlock
                                Text="↩ Original message was deleted"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                FontStyle="Italic" />
                        </Border>

                        <!-- ── Author + Timestamp + Edited ─────────── -->
                        <StackPanel
                            Grid.Row="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            Margin="0,0,0,4">
                            <TextBlock
                                Text="{x:Bind Author.Name, FallbackValue='Unknown'}"
                                Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBlock
                                Text="{x:Bind Date}"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                VerticalAlignment="Center" />
                            <Border
                                Visibility="{x:Bind IsEdited, Converter={StaticResource BoolToVisibility}}"
                                Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                                CornerRadius="2"
                                Padding="4,1">
                                <TextBlock
                                    Text="edited"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontStyle="Italic" />
                            </Border>
                        </StackPanel>

                        <!-- ── Message Content with @mention highlighting ── -->
                        <TextBlock
                            Grid.Row="2"
                            Text="{x:Bind Message, FallbackValue=''}"
                            TextWrapping="Wrap"
                            Style="{ThemeResource BodyTextBlockStyle}"
                            Margin="0,0,0,4"
                            Visibility="{x:Bind Message, Mode=OneWay, Converter={StaticResource NullToCollapsed}}" />       

                        <!-- ── Media Indicator ─────────────────────── -->
                        <StackPanel
                            Grid.Row="3"
                            Orientation="Horizontal"
                            Spacing="6"
                            Margin="0,0,0,4"
                            Visibility="{x:Bind MediaPath, Mode=OneWay, Converter={StaticResource NullToCollapsed}}">
                            <FontIcon Glyph="&#xE722;" FontSize="14"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock
                                Text="Media attached"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        </StackPanel>

                        <!-- ── Reaction Display ────────────────────── -->
                        <ItemsRepeater
                            Grid.Row="4"
                            ItemsSource="{x:Bind ReactionGroups, Mode=OneWay}"
                            Margin="0,0,0,4"
                            Visibility="{x:Bind HasReactions, Converter={StaticResource BoolToVisibility}}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="4" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:ReactionGroup">
                                    <Border
                                        Padding="6,2"
                                        CornerRadius="10"
                                        BorderThickness="1"
                                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{x:Bind Emoji}" FontSize="14" />
                                            <TextBlock Text="{x:Bind Count}" FontSize="12"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <!-- ── Actions Row ─────────────────────────── -->
                        <StackPanel
                            Grid.Row="5"
                            Orientation="Horizontal"
                            Spacing="4">

                            <Button
                                Content="↩ Reply"
                                FontSize="12"
                                Padding="6,2"
                                Tag="{x:Bind}"
                                Click="OnReplyClicked" />

                            <Button
                                FontSize="12"
                                Padding="6,2"
                                Tag="{x:Bind}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE76E;" FontSize="12" />
                                    <TextBlock Text="React" />
                                </StackPanel>
                                <Button.Flyout>
                                    <Flyout>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Button Content="👍" Click="OnEmojiClicked" Tag="👍" FontSize="18" Padding="6,2" />
                                            <Button Content="❤️" Click="OnEmojiClicked" Tag="❤️" FontSize="18" Padding="6,2" />
                                            <Button Content="😂" Click="OnEmojiClicked" Tag="😂" FontSize="18" Padding="6,2" />
                                            <Button Content="😮" Click="OnEmojiClicked" Tag="😮" FontSize="18" Padding="6,2" />
                                            <Button Content="😢" Click="OnEmojiClicked" Tag="😢" FontSize="18" Padding="6,2" />
                                            <Button Content="🔥" Click="OnEmojiClicked" Tag="🔥" FontSize="18" Padding="6,2" />
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>

                            <Button
                                Content="🗑 Delete"
                                FontSize="12"
                                Padding="6,2"
                                Tag="{x:Bind}"
                                Visibility="{x:Bind CanDelete, Converter={StaticResource BoolToVisibility}}"
                                Click="OnDeleteClicked" />

                            <!-- Admin-only Mute button -->
                            <Button
                                FontSize="12"
                                Padding="6,2"
                                Tag="{x:Bind}"
                                Visibility="{x:Bind ShowMuteButton, Converter={StaticResource BoolToVisibility}}"
                                Click="OnMuteClicked">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                    <TextBlock Text="Mute" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.Footer>
                <TextBlock
                    x:Name="EmptyStateText"
                    Text="No messages yet. Start the conversation!"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center"
                    Margin="0,24"
                    Visibility="Collapsed" />
            </ListView.Footer>
        </ListView>

        <!-- ═══════════════════════════════════════════════════════
             ROW 3 — Reply Preview + Mute Banner + Media Preview
             ═══════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="3" Spacing="0">

            <Border
                Visibility="{x:Bind ViewModel.IsInReplyMode, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                Padding="12,8"
                BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                BorderThickness="0,1,0,0">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                        <TextBlock
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            FontWeight="SemiBold">
                            <Run Text="Replying to " /><Run Text="{x:Bind ViewModel.ReplyTarget.Author.Name, Mode=OneWay, FallbackValue=''}" />
                        </TextBlock>
                        <TextBlock
                            Text="{x:Bind ViewModel.ReplyTarget.Message, Mode=OneWay, FallbackValue=''}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            MaxLines="1"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        Command="{x:Bind ViewModel.CancelReplyCommand}"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="Cancel reply">
                        <FontIcon Glyph="&#xE711;" FontSize="12" />
                    </Button>
                </Grid>
            </Border>

            <Border
                Visibility="{x:Bind ViewModel.IsMuted, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                Padding="12,8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                    <TextBlock
                        Text="{x:Bind ViewModel.MuteRemainingText, Mode=OneWay, FallbackValue='You are muted.'}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border
                Visibility="{x:Bind ViewModel.MediaPath, Mode=OneWay, Converter={StaticResource NullToCollapsed}}"
                Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                Padding="12,8">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <FontIcon Grid.Column="0" Glyph="&#xE722;" FontSize="14" Margin="0,0,8,0" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{x:Bind ViewModel.MediaPath, Mode=OneWay}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        TextTrimming="CharacterEllipsis"
                        VerticalAlignment="Center" />
                    <Button
                        Grid.Column="2"
                        Click="OnClearMediaClicked"
                        ToolTipService.ToolTip="Remove attachment">
                        <FontIcon Glyph="&#xE711;" FontSize="12" />
                    </Button>
                </Grid>
            </Border>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════
             ROW 4 — Input Area
             ═══════════════════════════════════════════════════════ -->
        <Grid
            Grid.Row="4"
            ColumnDefinitions="Auto,*,Auto"
            Padding="8"
            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">

            <Button
                Grid.Column="0"
                Click="OnAttachMediaClicked"
                VerticalAlignment="Bottom"
                IsEnabled="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}"
                ToolTipService.ToolTip="Attach media"
                Margin="0,0,4,0">
                <FontIcon Glyph="&#xE723;" FontSize="16" />
            </Button>

            <TextBox
                Grid.Column="1"
                x:Name="MessageInput"
                Text="{x:Bind ViewModel.NewMessage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                PlaceholderText="Type a message... (use @Name to mention)"
                AcceptsReturn="False"
                IsEnabled="{x:Bind ViewModel.IsNotLoading, Mode=OneWay}"
                KeyDown="OnMessageInputKeyDown"
                Margin="0,0,4,0"
                VerticalAlignment="Center" />

            <Button
                Grid.Column="2"
                Command="{x:Bind ViewModel.SendMessageCommand}"
                VerticalAlignment="Bottom"
                Style="{ThemeResource AccentButtonStyle}"
                ToolTipService.ToolTip="Send message">
                <FontIcon Glyph="&#xE724;" FontSize="16" />
            </Button>
        </Grid>

        <!-- Loading overlay -->
        <ProgressRing
            Grid.Row="2"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center" />
    </Grid>
</UserControl>
