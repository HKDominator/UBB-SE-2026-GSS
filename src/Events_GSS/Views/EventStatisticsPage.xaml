<Page
    x:Class="Events_GSS.Views.EventStatisticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Events_GSS.Data.Models">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header ──────────────────────────────────────── -->
        <Grid
            Grid.Row="0"
            Padding="16,12"
            Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
            ColumnDefinitions="Auto,*">

            <Button
                Grid.Column="0"
                Click="OnBackClicked"
                VerticalAlignment="Center"
                Margin="0,0,12,0">
                <FontIcon Glyph="&#xE72B;" FontSize="16" />
            </Button>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock
                    x:Name="PageTitle"
                    Style="{ThemeResource TitleTextBlockStyle}"
                    Text="Event Statistics" />
                <TextBlock
                    x:Name="EventNameText"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- ── Loading indicator ───────────────────────────── -->
        <ProgressRing
            Grid.Row="1"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="48" Height="48" />

        <!-- ── Error message ───────────────────────────────── -->
        <InfoBar
            Grid.Row="1"
            IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
            Severity="Error"
            Title="Error"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            Margin="16"
            VerticalAlignment="Top" />

        <!-- ── Statistics Content ──────────────────────────── -->
        <ScrollViewer Grid.Row="1" Padding="24,16,24,24">
            <StackPanel Spacing="24">

                <!-- ═══ 10.1 Participant Overview ═══ -->
                <TextBlock Text="Participant Overview" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <Grid
                    ColumnDefinitions="*,*,*"
                    ColumnSpacing="16"
                    Padding="0,0,0,8">

                    <!-- Total Participants -->
                    <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE77B;" FontSize="28" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.ParticipantOverview.TotalParticipants, Mode=OneWay}"
                                       Style="{ThemeResource TitleLargeTextBlockStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Total Participants (e)"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Active Participants -->
                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE8FA;" FontSize="28" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.ParticipantOverview.ActiveParticipants, Mode=OneWay}"
                                       Style="{ThemeResource TitleLargeTextBlockStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Active Participants"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Engagement Rate -->
                    <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE9D9;" FontSize="28" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Center" />
                            <TextBlock x:Name="EngagementRateText"
                                       Style="{ThemeResource TitleLargeTextBlockStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Engagement Rate (e)"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>

                <MenuFlyoutSeparator />

                <!-- ═══ 10.2 Engagement Breakdown ═══ -->
                <TextBlock Text="Engagement Breakdown" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <Grid
                    ColumnDefinitions="*,*,*"
                    ColumnSpacing="16"
                    Padding="0,0,0,4">

                    <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE8BD;" FontSize="28" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.EngagementBreakdown.TotalDiscussionMessages, Mode=OneWay}"
                                       Style="{ThemeResource TitleLargeTextBlockStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Discussion Messages"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE8B9;" FontSize="28" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.EngagementBreakdown.TotalMemories, Mode=OneWay}"
                                       Style="{ThemeResource TitleLargeTextBlockStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Memories"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE9D5;" FontSize="28" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.EngagementBreakdown.TotalQuestSubmissions, Mode=OneWay}"
                                       Style="{ThemeResource TitleLargeTextBlockStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Quest Submissions"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Approved vs Denied Rate -->
                <Grid
                    ColumnDefinitions="*,*"
                    ColumnSpacing="16"
                    Padding="0,0,0,8">

                    <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE8FB;" FontSize="24" Foreground="Green" HorizontalAlignment="Center" />
                            <TextBlock x:Name="ApprovedRateText"
                                       Style="{ThemeResource TitleLargeTextBlockStyle}"
                                       Foreground="Green"
                                       HorizontalAlignment="Center" />
                            <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center">
                                <Run Text="Approved (" /><Run x:Name="ApprovedCountText" /><Run Text=")" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE711;" FontSize="24" Foreground="IndianRed" HorizontalAlignment="Center" />
                            <TextBlock x:Name="DeniedRateText"
                                       Style="{ThemeResource TitleLargeTextBlockStyle}"
                                       Foreground="IndianRed"
                                       HorizontalAlignment="Center" />
                            <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center">
                                <Run Text="Denied (" /><Run x:Name="DeniedCountText" /><Run Text=")" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <MenuFlyoutSeparator />

                <!-- ═══ 10.3 Participant Leaderboard ═══ -->
                <TextBlock Text="Participant Leaderboard" Style="{ThemeResource SubtitleTextBlockStyle}" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="0">
                    <Grid RowDefinitions="Auto,*">
                        <!-- Header row -->
                        <Grid Grid.Row="0" Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                              Padding="12,8" ColumnDefinitions="40,*,120,80,80,80,80">
                            <TextBlock Grid.Column="0" Text="#" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="User" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="Tier" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="Messages" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="Memories" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="5" Text="Quests" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="6" Text="Score" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Grid>

                        <!-- Leaderboard list -->
                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Leaderboard, Mode=OneWay}"
                                  SelectionMode="None"
                                  MaxHeight="500">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:LeaderboardEntry">
                                    <Grid Padding="12,6" ColumnDefinitions="40,*,120,80,80,80,80">
                                        <TextBlock Grid.Column="0" Text="{x:Bind}" VerticalAlignment="Center"
                                                   Visibility="Collapsed" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind UserName}" VerticalAlignment="Center" />
                                        <Border Grid.Column="2" Background="{ThemeResource SystemAccentColorLight3}"
                                                CornerRadius="4" Padding="6,2" HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Tier}" FontSize="12" />
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="{x:Bind MessagesCount}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="4" Text="{x:Bind MemoriesCount}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="5" Text="{x:Bind QuestsCompleted}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="6" Text="{x:Bind TotalScore}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   FontWeight="Bold" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <MenuFlyoutSeparator />

                <!-- ═══ 10.4 Quest Analytics ═══ -->
                <TextBlock Text="Quest Analytics" Style="{ThemeResource SubtitleTextBlockStyle}" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="0">
                    <Grid RowDefinitions="Auto,*">
                        <!-- Header row -->
                        <Grid Grid.Row="0" Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                              Padding="12,8" ColumnDefinitions="*,120">
                            <TextBlock Grid.Column="0" Text="Quest Name" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Completed" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.QuestAnalytics, Mode=OneWay}"
                                  SelectionMode="None"
                                  MaxHeight="400">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:QuestAnalyticsEntry">
                                    <Grid Padding="12,6" ColumnDefinitions="*,120">
                                        <TextBlock Grid.Column="0" Text="{x:Bind QuestName}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind CompletedCount}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   FontWeight="SemiBold" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
