<Page
    x:Class="Events_GSS.Views.AttendedEventView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Events_GSS.Data.Models"
    xmlns:vm="using:Events_GSS.ViewModels"
    xmlns:converters="using:Events_GSS.Converters"
    x:Name="Root">

    <Page.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:BoolToInverseVisibilityConverter x:Key="BoolToInverseVisibilityConverter"/>
        <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
        <converters:UpcomingEventConverter x:Key="UpcomingEventConverter"/>
        <converters:FavouriteButtonTextConverter x:Key="FavouriteButtonTextConverter"/>
    </Page.Resources>

    <Grid RowDefinitions="Auto,Auto,*" Padding="24" RowSpacing="16">

        <TextBlock
            Grid.Row="0"
            Text="My Events"
            Style="{StaticResource TitleTextBlockStyle}" />

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
            <TextBox
                Grid.Column="0"
                PlaceholderText="Search events by title..."
                Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <ComboBox
                Grid.Column="1"
                PlaceholderText="Category"
                ItemsSource="{Binding AvailableCategories}"
                SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                MinWidth="140">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:Category">
                        <TextBlock Text="{Binding Title}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <ComboBox
                Grid.Column="2"
                PlaceholderText="Sort by"
                ItemsSource="{Binding SortOptions}"
                SelectedItem="{Binding SelectedSort, Mode=TwoWay}"
                MinWidth="160">
            </ComboBox>

            <Button
                Grid.Column="3"
                Content="Clear"
                Command="{Binding ClearFiltersCommand}" />
        </Grid>

        <Grid Grid.Row="2">
            <ProgressRing
                IsActive="{Binding IsLoading}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding IsLoading}" />

            <TextBlock
                Text="{Binding ErrorMessage}"
                Foreground="Red"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

            <TabView
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToInverseVisibilityConverter}}"
                TabWidthMode="Equal"
                IsAddTabButtonVisible="False">

                <TabViewItem Header="Attending">
                    <ListView ItemsSource="{Binding AttendedEvents}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:AttendedEvent">
                                <Border
                                    Padding="16,12"
                                    Margin="0,4"
                                    CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">

                                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                            <TextBlock
                                                Text="{Binding Event.Name}"
                                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <Border
                                                Background="#FF8C00"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Visibility="{Binding Event, Converter={StaticResource UpcomingEventConverter}}">
                                                <TextBlock Text="Soon" Foreground="White" FontSize="11"/>
                                            </Border>
                                            <TextBlock
                                                Text="⭐"
                                                FontSize="14"
                                                Visibility="{Binding IsFavourite}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                            <Button
                                                Content="{Binding IsFavourite, Converter={StaticResource FavouriteButtonTextConverter}}"
                                                Tag="{Binding}"
                                                Click="FavouriteButton_Click"
                                                Style="{StaticResource DefaultButtonStyle}" />
                                            <Button
                                                Content="Archive"
                                                Tag="{Binding}"
                                                Click="ArchiveButton_Click" />
                                            <Button
                                            Content="Leave"
                                            Tag="{Binding}"
                                            Click="LeaveButton_Click"
                                            Style="{StaticResource DefaultButtonStyle}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                    Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                            <TextBlock
                                                Text="{Binding Event.Category.Title}"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                FontSize="13" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                FontSize="13">
                                                <Run Text="{Binding Event.StartDateTime}" />
                                                <Run Text=" → " />
                                                <Run Text="{Binding Event.EndDateTime}" />
                                            </TextBlock>
                                        </StackPanel>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>

                        <ListView.Footer>
                            <TextBlock
                                Text="No events found."
                                HorizontalAlignment="Center"
                                Margin="0,24"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Visibility="{Binding AttendedEvents.Count,
                                    Converter={StaticResource ZeroToVisibilityConverter}}" />
                        </ListView.Footer>
                    </ListView>
                </TabViewItem>

                <TabViewItem Header="Archived">
                    <ListView ItemsSource="{Binding ArchivedEvents}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:AttendedEvent">
                                <Border
                                    Padding="16,12"
                                    Margin="0,4"
                                    CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Opacity="0.7">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock
                                                Text="{Binding Event.Name}"
                                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock
                                                Text="{Binding Event.Category.Title}"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                FontSize="13" />
                                        </StackPanel>
                                        <Button
                                            Grid.Column="1"
                                            Content="Unarchive"
                                            Tag="{Binding}"
                                            Click="ArchiveButton_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabViewItem>

                <TabViewItem Header="Favourites">
                    <ListView ItemsSource="{Binding FavouriteEvents}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:AttendedEvent">
                                <Border
                                    Padding="16,12"
                                    Margin="0,4"
                                    CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock
                                                Text="{Binding Event.Name}"
                                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <StackPanel Orientation="Horizontal" Spacing="16">
                                                <TextBlock
                                                    Text="{Binding Event.Category.Title}"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    FontSize="13" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    FontSize="13">
                                                    <Run Text="{Binding Event.StartDateTime}" />
                                                    <Run Text=" → " />
                                                    <Run Text="{Binding Event.EndDateTime}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button
                                            Grid.Column="1"
                                            Content="Unfavourite"
                                            CommandParameter="{Binding}"
                                            Command="{Binding DataContext.SetFavouriteCommand,
                                                ElementName=Root}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabViewItem>

            </TabView>
        </Grid>
    </Grid>
</Page>
