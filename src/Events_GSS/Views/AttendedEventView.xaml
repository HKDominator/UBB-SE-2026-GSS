<Page
    x:Class="Events_GSS.Views.AttendedEventView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Events_GSS.Data.Models"
    xmlns:vm="using:Events_GSS.ViewModels"
    xmlns:converters="using:Events_GSS.Converters"
    x:Name="Root">

    <Page.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:BoolToInverseVisibilityConverter x:Key="BoolToInverseVisibilityConverter"/>
        <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
        <converters:UpcomingEventConverter x:Key="UpcomingEventConverter"/>
        <converters:FavouriteButtonTextConverter x:Key="FavouriteButtonTextConverter"/>
        <converters:AchievementOpacityConverter x:Key="AchievementOpacityConverter"/>
        <converters:AchievementBadgeConverter x:Key="AchievementBadgeConverter"/>
        <converters:AchievementStatusConverter x:Key="AchievementStatusConverter"/>
        <converters:NonZeroToVisibilityConverter x:Key="NonZeroToVisibilityConverter"/>
    </Page.Resources>

    <Grid RowDefinitions="Auto,Auto,*" Padding="24" RowSpacing="16">

        <TextBlock
            Grid.Row="0"
            Text="My Events"
            Style="{StaticResource TitleTextBlockStyle}" />

        <!-- Search, filter and sort bar -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
            <TextBox
                Grid.Column="0"
                PlaceholderText="Search events by title..."
                Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <ComboBox
                Grid.Column="1"
                PlaceholderText="Category"
                ItemsSource="{Binding AvailableCategories}"
                SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                MinWidth="140">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:Category">
                        <TextBlock Text="{Binding Title}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <ComboBox
                Grid.Column="2"
                PlaceholderText="Sort by"
                ItemsSource="{Binding SortOptions}"
                SelectedItem="{Binding SelectedSort, Mode=TwoWay}"
                MinWidth="160">
            </ComboBox>

            <Button
                Grid.Column="4"
                Content="Clear"
                Command="{Binding ClearFiltersCommand}" />
        </Grid>

        <Grid Grid.Row="2">
            <ProgressRing
                IsActive="{Binding IsLoading}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding IsLoading}" />

            <TextBlock
                Text="{Binding ErrorMessage}"
                Foreground="Red"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

            <TabView
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToInverseVisibilityConverter}}"
                TabWidthMode="Equal"
                IsAddTabButtonVisible="False">

                <TabViewItem Header="Attending">
                    <ListView ItemsSource="{Binding AttendedEvents}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:AttendedEvent">
                                <Border
                                    Padding="16,12"
                                    Margin="0,4"
                                    CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">

                                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                            <TextBlock
                                                Text="{Binding Event.Name}"
                                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <Border
                                                Background="#FF8C00"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Visibility="{Binding Event, Converter={StaticResource UpcomingEventConverter}}">
                                                <TextBlock Text="Soon" Foreground="White" FontSize="11"/>
                                            </Border>
                                            <TextBlock
                                                Text="⭐"
                                                FontSize="14"
                                                Visibility="{Binding IsFavourite}" />
                                            <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="8" Padding="6,2" MinWidth="20"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding UnreadAnnouncementCount, 
                                                    Converter={StaticResource NonZeroToVisibilityConverter}}">
                                                                                    <TextBlock Text="{Binding UnreadAnnouncementCount}"
                                                       Foreground="White" FontSize="11"
                                                       HorizontalAlignment="Center"/>
                                            </Border>       
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                            <Button
                                            Content="Details"
                                            Tag="{Binding Event}"
                                            Click="DetailsButton_Click" />
                                            <Button
                                                Content="{Binding IsFavourite, Converter={StaticResource FavouriteButtonTextConverter}}"
                                                Tag="{Binding}"
                                                Click="FavouriteButton_Click"
                                                Style="{StaticResource DefaultButtonStyle}" />
                                            <Button
                                                Content="Archive"
                                                Tag="{Binding}"
                                                Click="ArchiveButton_Click" />
                                            <Button
                                            Content="Leave"
                                            Tag="{Binding}"
                                            Click="LeaveButton_Click"
                                            Style="{StaticResource DefaultButtonStyle}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                    Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                            <TextBlock
                                                Text="{Binding Event.Category.Title}"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                FontSize="13" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                FontSize="13">
                                                <Run Text="{Binding Event.StartDateTime}" />
                                                <Run Text=" → " />
                                                <Run Text="{Binding Event.EndDateTime}" />
                                            </TextBlock>
                                        </StackPanel>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>

                        <ListView.Footer>
                            <TextBlock
                                Text="No events found."
                                HorizontalAlignment="Center"
                                Margin="0,24"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Visibility="{Binding AttendedEvents.Count,
                                    Converter={StaticResource ZeroToVisibilityConverter}}" />
                        </ListView.Footer>
                    </ListView>
                </TabViewItem>

                <TabViewItem Header="Archived">
                    <ListView ItemsSource="{Binding ArchivedEvents}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:AttendedEvent">
                                <Border
                                    Padding="16,12"
                                    Margin="0,4"
                                    CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Opacity="0.7">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock
                                                Text="{Binding Event.Name}"
                                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock
                                                Text="{Binding Event.Category.Title}"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                FontSize="13" />
                                        </StackPanel>
                                        <Button
                                            Grid.Column="1"
                                            Content="Unarchive"
                                            Tag="{Binding}"
                                            Click="ArchiveButton_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabViewItem>

                <TabViewItem Header="Favourites">
                    <ListView ItemsSource="{Binding FavouriteEvents}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:AttendedEvent">
                                <Border
                                    Padding="16,12"
                                    Margin="0,4"
                                    CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock
                                                Text="{Binding Event.Name}"
                                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <StackPanel Orientation="Horizontal" Spacing="16">
                                                <TextBlock
                                                    Text="{Binding Event.Category.Title}"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    FontSize="13" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    FontSize="13">
                                                    <Run Text="{Binding Event.StartDateTime}" />
                                                    <Run Text=" → " />
                                                    <Run Text="{Binding Event.EndDateTime}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button
                                            Grid.Column="1"
                                            Content="Unfavourite"
                                            Tag="{Binding}"
                                            Click="FavouriteButton_Click"
                                            />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabViewItem>

<TabViewItem Header="Reputation">
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center"
          DataContext="{Binding DataContext.ReputationViewModel, ElementName=Root}">
        <Border CornerRadius="12" Padding="48,32"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                HorizontalAlignment="Stretch"
                Margin="24">
            <StackPanel HorizontalAlignment="Center" Spacing="10">
                <TextBlock Text="{Binding UserName}" FontSize="16"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                    <TextBlock Text="{Binding ReputationPoints}" FontSize="40"
                               FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="RP" FontSize="20" VerticalAlignment="Bottom"
                               Margin="0,0,0,6"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
                <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="14" Padding="16,6" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CurrentTier}" FontSize="16"
                               FontWeight="SemiBold" Foreground="White"
                               HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</TabViewItem>

<TabViewItem Header="Common Events">
    <StackPanel>
        <AutoSuggestBox
        Grid.Column="3"
        Text="{Binding FriendSearchQuery, Mode=TwoWay}"
        ItemsSource="{Binding FilteredFriends}"
        PlaceholderText="Friend"
        DisplayMemberPath="Name"
        SuggestionChosen="FriendBox_Chosen"
        MinWidth="240"
        >
        </AutoSuggestBox>
        <ListView ItemsSource="{Binding CommonEvents}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:AttendedEvent">
                    <Border Padding="16,12" Margin="0,4" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding Event.Name}"
                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <TextBlock Text="{Binding Event.Category.Title}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="13"/>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="13">
                    <Run Text="{Binding Event.StartDateTime}"/>
                    <Run Text=" → "/>
                    <Run Text="{Binding Event.EndDateTime}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</TabViewItem>

            </TabView>
        </Grid>
    </Grid>
</Page>
