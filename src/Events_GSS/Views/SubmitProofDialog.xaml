<ContentDialog
    x:Class="Events_GSS.Views.SubmitProofDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    PrimaryButtonText="Submit"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonClick="OnSubmitClicked">

    <StackPanel Spacing="12" MinWidth="360">

        <TextBlock x:Name="QuestNameText"
                   Style="{StaticResource SubtitleTextBlockStyle}"/>

        <TextBox x:Name="ImageUrlBox"
                 Header="Image URL (optional)"
                 PlaceholderText="https://..."/>

        <TextBox x:Name="DescriptionBox"
                 Header="Description (optional)"
                 PlaceholderText="Describe how you completed this quest..."
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="80"/>

        <TextBlock x:Name="ValidationText"
                   Foreground="Red"
                   Visibility="Collapsed"/>

    </StackPanel>
</ContentDialog>