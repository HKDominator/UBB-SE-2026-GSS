<Page
    x:Class="Events_GSS.Views.ReputationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Events_GSS.Data.Models"
    xmlns:converters="using:Events_GSS.Converters">

    <Page.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:BoolToInverseVisibilityConverter x:Key="BoolToInverseVisibilityConverter"/>
        <converters:AchievementOpacityConverter x:Key="AchievementOpacityConverter"/>
        <converters:AchievementBadgeConverter x:Key="AchievementBadgeConverter"/>
        <converters:AchievementStatusConverter x:Key="AchievementStatusConverter"/>
    </Page.Resources>

    <Grid Padding="24" RowDefinitions="Auto,*" RowSpacing="16">

        <TextBlock Grid.Row="0" Text="Reputation" Style="{StaticResource TitleTextBlockStyle}" />

        <Grid Grid.Row="1">
            <ProgressRing IsActive="{Binding IsLoading}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding IsLoading}" />

            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

            <ScrollViewer Visibility="{Binding IsLoading, Converter={StaticResource BoolToInverseVisibilityConverter}}">
                <StackPanel Spacing="24" MaxWidth="700" HorizontalAlignment="Stretch">

                    <Border CornerRadius="12" Padding="32,24" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center" Spacing="10">
                            <TextBlock Text="{Binding UserName}" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                                <TextBlock Text="{Binding ReputationPoints}" FontSize="40" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="RP" FontSize="20" VerticalAlignment="Bottom" Margin="0,0,0,6" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="14" Padding="16,6" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding CurrentTier}" FontSize="16" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="8" Padding="16,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Tier Thresholds" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0"><TextBlock Text="Newcomer" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/><TextBlock Grid.Column="1" Text="0 RP" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/></Grid>
                            <Grid ColumnDefinitions="*,Auto"><TextBlock Text="Contributor" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/><TextBlock Grid.Column="1" Text="50 RP" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/></Grid>
                            <Grid ColumnDefinitions="*,Auto"><TextBlock Text="Organizer" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/><TextBlock Grid.Column="1" Text="200 RP" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/></Grid>
                            <Grid ColumnDefinitions="*,Auto"><TextBlock Text="Community Leader" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/><TextBlock Grid.Column="1" Text="500 RP" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/></Grid>
                            <Grid ColumnDefinitions="*,Auto"><TextBlock Text="Event Master" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/><TextBlock Grid.Column="1" Text="1000 RP" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/></Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Achievements" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,4,0,0"/>

                    <ItemsRepeater ItemsSource="{Binding Achievements}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="8"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:Achievement">
                                <Border Padding="16,12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Opacity="{Binding IsUnlocked, Converter={StaticResource AchievementOpacityConverter}}">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" CornerRadius="10" Padding="8,4" VerticalAlignment="Center" Background="{Binding IsUnlocked, Converter={StaticResource AchievementBadgeConverter}}">
                                            <TextBlock Text="{Binding IsUnlocked, Converter={StaticResource AchievementStatusConverter}}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
