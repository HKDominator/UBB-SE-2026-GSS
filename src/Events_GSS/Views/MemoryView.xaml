<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Events_GSS.Views.MemoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Events_GSS.Data.Models">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Grid Grid.Row="0" Margin="16,16,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Memories"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="📷 Gallery"
                    Margin="0,0,8,0"
                    Click="GalleryButton_Click"/>
            <Button Grid.Column="2"
                    Content="+ Add Memory"
                    Click="AddMemoryButton_Click"/>
        </Grid>

        <!-- ── Filters ── -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="16,0,16,8">
            <ToggleButton x:Name="MyMemoriesToggle"
                          Content="My Memories"
                          Click="MyMemoriesToggle_Click"/>
            <Button Content="Date ↑"
                    Click="SortAscending_Click"/>
            <Button Content="Date ↓"
                    Click="SortDescending_Click"/>
        </StackPanel>

        <!-- ── Content area ── -->
        <Grid Grid.Row="2">

            <!-- Memory List -->
            <ScrollViewer x:Name="MemoryListScrollViewer"
                          Padding="16,0,16,16">
                <StackPanel Spacing="12">

                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  HorizontalAlignment="Center"
                                  Margin="0,20,0,20"/>

                    <TextBlock x:Name="ErrorText"
                               Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                               Foreground="Red"
                               Visibility="Collapsed"
                               Margin="0,0,0,8"/>

                    <TextBlock x:Name="EmptyText"
                               Text="No memories yet. Be the first to add one!"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Margin="0,40,0,0"
                               Visibility="Collapsed"/>

                    <ItemsControl x:Name="MemoriesControl"
                                  ItemsSource="{x:Bind ViewModel.Memories, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Memory">
                                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,0,0,8"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <StackPanel Spacing="8">

                                        <!-- Photo -->
                                        <Border CornerRadius="4" Margin="4">
                                            <Image Source="{x:Bind PhotoPath, Mode=OneWay}"
                                                   Width="250"
                                                   Height="200"
                                                   Stretch="UniformToFill"/>
                                        </Border>


                                        <!-- Text -->
                                        <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                                                   TextWrapping="Wrap"
                                                   FontSize="14"/>

                                        <!-- Footer -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind CreatedAt, Mode=OneWay}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center"/>

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        Spacing="4"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0">
                                                <TextBlock Text="{x:Bind LikesCount, Mode=OneWay}"
                                                           VerticalAlignment="Center"
                                                           FontSize="14"/>
                                                <ToggleButton Content="♥"
                                                              IsChecked="{x:Bind IsLikedByCurrentUser, Mode=OneWay}"
                                                              Tag="{x:Bind MemoryId}"
                                                              Click="LikeButton_Click"
                                                              Padding="8,4"/>
                                            </StackPanel>

                                            <Button Grid.Column="2"
                                                    Content="🗑"
                                                    Tag="{x:Bind MemoryId}"
                                                    Click="DeleteButton_Click"
                                                    Padding="8,4"/>
                                        </Grid>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- Gallery View -->
            <Grid x:Name="GalleryGrid"
                  Padding="16,0,16,16"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Spacing="12"
                            Margin="0,0,0,12">
                    <TextBlock Text="Photo Gallery"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Button Content="← Back to Memories"
                            Click="CloseGallery_Click"/>
                </StackPanel>

                <GridView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.GalleryPhotos, Mode=OneWay}">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Border CornerRadius="4" Margin="4">
                                <Image Source="{x:Bind}"
                                       Width="150"
                                       Height="150"
                                       Stretch="UniformToFill"/>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

            </Grid>

        </Grid>

    </Grid>
</UserControl>