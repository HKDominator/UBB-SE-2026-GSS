<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Events_GSS.Views.MemoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:Events_GSS.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="16,16,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="📷 Gallery"
                    Margin="0,0,8,0"
                    Visibility="{x:Bind ViewModel.IsMemoryListVisible, Mode=OneWay}"
                    Command="{x:Bind ViewModel.OpenGalleryCommand}"/>

            <Button Grid.Column="2"
                    Content="+ Add Memory"
                    Visibility="{x:Bind ViewModel.IsMemoryListVisible, Mode=OneWay}"
                    Click="AddMemoryButton_Click"/>
        </Grid>

        <!-- Filters -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="16,0,16,8"
                    Visibility="{x:Bind ViewModel.IsMemoryListVisible, Mode=OneWay}">

            <ToggleButton x:Name="MyMemoriesToggle"
                          Content="My Memories"
                          Click="MyMemoriesToggle_Click"/>

            <Button Content="Date ↑"
                    Click="SortButton_Click"
                    Command="{x:Bind ViewModel.SortAscendingCommand}"/>

            <Button Content="Date ↓"
                    Click="SortButton_Click"
                    Command="{x:Bind ViewModel.SortDescendingCommand}"/>
        </StackPanel>

        <!-- Content area -->
        <Grid Grid.Row="2">

            <!-- Memory list -->
            <ScrollViewer Padding="16,0,16,16"
                          Visibility="{x:Bind ViewModel.IsMemoryListVisible, Mode=OneWay}">
                <StackPanel Spacing="12">

                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  HorizontalAlignment="Center"
                                  Margin="0,20,0,20"/>

                    <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                               Foreground="Red"
                               Visibility="{x:Bind ViewModel.HasError, Mode=OneWay}"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="No memories yet. Be the first to add one!"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Margin="0,40,0,0"
                               Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"/>

                    <ItemsControl ItemsSource="{x:Bind ViewModel.Memories, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:MemoryItemViewModel">
                                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,0,0,8"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <StackPanel Spacing="8">

                                        <Border CornerRadius="4"
                                                Margin="4"
                                                Visibility="{x:Bind HasPhoto, Mode=OneWay}">
                                            <Image Source="{x:Bind PhotoPath, Mode=OneWay}"
                                                   Stretch="Uniform"
                                                   MaxHeight="250"/>
                                        </Border>

                                        <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                                                   TextWrapping="Wrap"
                                                   FontSize="14"
                                                   Visibility="{x:Bind HasText, Mode=OneWay}"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0"
                                                        Orientation="Vertical"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind CreatedAt, Mode=OneWay}"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock Text="{x:Bind AuthorName, Mode=OneWay}"
                                                           FontSize="11"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        Spacing="4"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"
                                                        Visibility="{x:Bind CanLike, Mode=OneWay}">
                                                <TextBlock Text="{x:Bind LikesCount, Mode=OneWay}"
                                                           VerticalAlignment="Center"
                                                           FontSize="14"/>
                                                <ToggleButton Content="♥"
                                                              IsChecked="{x:Bind IsLikedByCurrentUser, Mode=OneWay}"
                                                              Click="LikeButton_Click"
                                                              Padding="8,4"/>
                                            </StackPanel>

                                            <Button Grid.Column="2"
                                                    Content="🗑"
                                                    Click="DeleteButton_Click"
                                                    Visibility="{x:Bind CanDelete, Mode=OneWay}"
                                                    Padding="8,4"/>
                                        </Grid>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- Gallery -->
            <Grid Padding="16,0,16,16"
                  Visibility="{x:Bind ViewModel.IsGalleryVisible, Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Spacing="12"
                            Margin="0,0,0,12">
                    <TextBlock Text="Photo Gallery"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Button Content="← Back to Memories"
                            Command="{x:Bind ViewModel.CloseGalleryCommand}"/>
                </StackPanel>

                <GridView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.GalleryPhotos, Mode=OneWay}">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Border CornerRadius="4" Margin="4">
                                <Image Source="{x:Bind}"
                                       Width="150"
                                       Height="150"
                                       Stretch="UniformToFill"/>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
